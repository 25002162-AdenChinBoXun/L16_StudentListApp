<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Student List App</title>
</head>
<body class="bg-light">
    
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
          <a class="navbar-brand" href="/">Student App</a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="collapsibleNavbar">
            <ul class="navbar-nav">
              <li class="nav-item">
                <a class="nav-link" href="/addStudent">Add New Student</a>
              </li> 
            </ul>
          </div>
        </div>
    </nav>
    
    <div class="container mt-5">
        <h2 class="text-center mb-4">Student Roster</h2>
        
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle bg-white shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Date of Birth</th>
                        <th>Contact</th>
                        <th>View/Edit/Delete</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (students && students.length > 0) { %>
                        <% students.forEach(student => { %>
                            <tr>
                                <td>
                                    <img src="<%= student.image %>" alt="<%= student.name %>" style="width: 80px; height: 80px; object-fit: cover;" class="rounded">
                                </td>
                                
                                <td><%= student.name %></td>
                                <td><%= student.dob.toLocaleDateString('en-GB') %></td>
                                <td><%= student.contact %></td>
                                
                                <td>
                                    <a href="/student/<%= student.studentId %>" class="btn btn-primary btn-sm">View Details</a>
                                    <a href="/editStudent/<%= student.studentId %>" class="btn btn-warning btn-sm">Edit</a>
                                    <a href="/deleteStudent/<%= student.studentId %>" class="btn btn-danger btn-sm" 
                                        onclick="return confirm('Are you sure you want to delete this student?');">Delete</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No students found. Go ahead and add some!</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
    
</body>
</html>